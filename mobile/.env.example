# Mobile App Environment Variables
# Скопируйте этот файл как .env и настройте при необходимости

# Backend API URL
# Для локальной разработки:
API_URL=http://localhost:4000

# Для Android эмулятора используйте 10.0.2.2 вместо localhost:
# API_URL=http://10.0.2.2:4000

# WebSocket URL
# Для локальной разработки:
WS_URL=ws://localhost:4000

# Для Android эмулятора:
# WS_URL=ws://10.0.2.2:4000

# Интервал отправки GPS в миллисекундах
GPS_INTERVAL_MS=4000

# Production URLs (раскомментируйте для продакшена)
# API_URL=https://api.your-company.com
# WS_URL=wss://api.your-company.com
