{
  "name": "corporate-transport-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --tsconfig tsconfig.json src/db/seed.ts"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/websocket": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/cookie": "^11.0.1",
    "@prisma/client": "^6.1.0",
    "redis": "^4.7.0",
    "bcryptjs": "^2.4.3",
    "zod": "^3.24.1",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "prisma": "^6.1.0"
  }
}
